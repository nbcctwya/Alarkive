# Local paths (relative paths are resolved from the project directory)
ALARKIVE_DATA_DIR=./data
ALARKIVE_ASSETS_DIR=./data/assets
# DATABASE_URL=./data/alarkive.db

# Required in production unless ALARKIVE_AUTH_DISABLED=true is explicitly set.
ALARKIVE_ADMIN_USERNAME=admin
ALARKIVE_ADMIN_PASSWORD=replace-with-a-long-random-password

# Caddy site address. Use a domain for automatic HTTPS, or http://PUBLIC_IP
# for an initial IP-only deployment (Basic Auth is not encrypted over HTTP).
ALARKIVE_SITE_ADDRESS=http://localhost

# Optional registry overrides for hosts that cannot reach Docker Hub.
ALARKIVE_NODE_IMAGE=node:22-alpine
ALARKIVE_CADDY_IMAGE=caddy:2.11.4-alpine
# ALARKIVE_ALPINE_MIRROR=https://mirrors.aliyun.com/alpine
# ALARKIVE_NODE_HEADERS_MIRROR=https://nodejs.org/download/release
