{
  "name": "alarkive",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build && node scripts/prepare-standalone.mjs",
    "start": "node .next/standalone/server.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm test",
    "test:watch": "vitest",
    "test:e2e": "node tests/e2e/run-playwright.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:init": "node --import tsx scripts/init-db.ts",
    "db:seed": "node --import tsx scripts/seed.ts",
    "db:reset": "node --import tsx scripts/reset-db.ts",
    "db:verify": "node --import tsx scripts/verify-persistence.ts",
    "db:backup": "node --import tsx scripts/backup-db.ts",
    "db:restore": "node --import tsx scripts/restore-db.ts",
    "docker:verify": "sh scripts/verify-docker.sh"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.1.11",
    "better-sqlite3": "^12.2.0",
    "drizzle-orm": "^0.45.2",
    "github-slugger": "^2.0.0",
    "jszip": "^3.10.1",
    "katex": "^0.16.22",
    "lucide-react": "^0.525.0",
    "next": "^15.5.20",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@playwright/test": "^1.61.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/katex": "^0.16.7",
    "@types/node": "^22.16.4",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.31.0",
    "eslint-config-next": "^15.5.20",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tailwindcss": "^4.1.11",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
